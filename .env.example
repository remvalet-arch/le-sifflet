# Supabase — copy to .env.local and fill from Project Settings > API
# https://supabase.com/dashboard/project/_/settings/api
#
# Auth Google : Dashboard → Authentication → Providers → Google (client ID/secret).
# Redirect URLs autorisées : http://localhost:3000/auth/callback (+ URL prod).
# Côté Google Cloud Console : URI de redirection autorisée =
#   https://<PROJECT_REF>.supabase.co/auth/v1/callback

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # Project Settings > API > service_role (secret, jamais côté client)

# Optionnel : URL canonique pour metadata / liens absolus (ex. https://lesifflet.vercel.app)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Tests automatisés ────────────────────────────────────────────────────────
# Secret aléatoire pour protéger l'endpoint /api/test/auth (dev uniquement)
# Générer avec : openssl rand -hex 32
TEST_AUTH_SECRET=your_random_secret_here

# Compte de test E2E Playwright (créé automatiquement par global-setup.ts si absent)
TEST_USER_EMAIL=e2e-player@le-sifflet.test
TEST_USER_PASSWORD=S1fflet-E2E-2026!

# URL de base pour les tests Playwright (défaut : http://localhost:3000)
# PLAYWRIGHT_BASE_URL=http://localhost:3000
