# Supabase — copy to .env.local and fill from Project Settings > API
# https://supabase.com/dashboard/project/_/settings/api
#
# Auth Google : Dashboard → Authentication → Providers → Google (client ID/secret).
# Redirect URLs autorisées : http://localhost:3000/auth/callback (+ URL prod).
# Côté Google Cloud Console : URI de redirection autorisée =
#   https://<PROJECT_REF>.supabase.co/auth/v1/callback

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # Project Settings > API > service_role (secret, jamais côté client)

# Web Push VAPID — générer avec : node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
# La clé publique est exposée au navigateur ; la clé privée reste strictement serveur.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:contact@lesifflet.app

# Optionnel : URL canonique pour metadata / liens absolus (ex. https://lesifflet.vercel.app)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Journée affichée au lobby (YYYY-MM-DD, fuseau Europe/Paris). Si absent : date du jour à Paris.
# NEXT_PUBLIC_LOBBY_DATE=2026-05-03

# ── Tests automatisés ────────────────────────────────────────────────────────
# Secret aléatoire pour protéger l'endpoint /api/test/auth (dev uniquement)
# Générer avec : openssl rand -hex 32
TEST_AUTH_SECRET=your_random_secret_here

# Compte de test E2E Playwright (créé automatiquement par global-setup.ts si absent)
TEST_USER_EMAIL=e2e-player@le-sifflet.test
TEST_USER_PASSWORD=S1fflet-E2E-2026!
SPORTSDB_API_KEY=459569

# URL de base pour les tests Playwright (défaut : http://localhost:3000)
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# TheSportsDB (v1 JSON) — cosmétique / import statique ; live migré vers API-Football
# SPORTSDB_API_KEY=your_thesportsdb_key
# (alias accepté : THESPORTSDB_API_KEY)

# API-Football (api-sports.io v3) — sync live (scores, compos, chronologie). Dashboard : https://www.api-football.com/
# API_FOOTBALL_KEY=your_api_football_key
# Saison API (année de début) : 2025 = compétitions 2025/2026 — ne pas mettre 2026 par erreur
# API_FOOTBALL_SEASON=2025

# Cron Vercel : même valeur que dans le dashboard Vercel → Settings → Environment Variables (`CRON_SECRET`).
# Vercel envoie `Authorization: Bearer <CRON_SECRET>` sur les invocations planifiées (ex. `/api/admin/sync-live`, `/api/cron/match-monitor`).
# Générer en local : openssl rand -hex 32
# CRON_SECRET=your_random_secret_here
#
# Délai (ms) entre deux `syncApiFootballMatch` dans le cron cycle de vie matchs (défaut 2500, plan PRO).
# MATCH_MONITOR_THROTTLE_MS=2500

# Délai entre ligues lors de l’import `GET /api/admin/sync-apifootball-fixtures` (Top 5, défaut 400 ms).
# API_FOOTBALL_TOP5_THROTTLE_MS=400
#
# Admin : `GET /api/admin/import-assets?league=French+Ligue+1` (modérateur ou Bearer CRON_SECRET) — import logos / couleurs / stades / portraits TSDB.
